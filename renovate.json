{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended",
    ":dependencyDashboard",
    ":semanticCommits"
  ],
  "labels": ["dependencies"],
  "pinDigests": true,
  "customManagers": [
    {
      "customType": "regex",
      "description": "Track pgvector source tag pinned in the Dockerfile",
      "managerFilePatterns": ["/(^|/)Dockerfile$/"],
      "matchStrings": [
        "# renovate: datasource=(?<datasource>\\S+) depName=(?<depName>\\S+)\\s+ARG PGVECTOR_VERSION=(?<currentValue>\\S+)"
      ],
      "extractVersionTemplate": "^v(?<version>.+)$"
    }
  ],
  "packageRules": [
    {
      "description": "Auto-merge GitHub Actions updates",
      "matchManagers": ["github-actions"],
      "automerge": true
    },
    {
      "description": "Auto-merge base image digest + PostgreSQL/PostGIS non-major bumps",
      "matchManagers": ["dockerfile"],
      "matchUpdateTypes": ["digest", "pin", "patch", "minor"],
      "automerge": true
    },
    {
      "description": "Auto-merge pgvector non-major releases",
      "matchDepNames": ["pgvector/pgvector"],
      "matchUpdateTypes": ["patch", "minor"],
      "automerge": true
    }
  ]
}
