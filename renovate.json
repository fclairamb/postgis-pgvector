{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended",
    ":dependencyDashboard",
    ":semanticCommits"
  ],
  "labels": ["dependencies"],
  "pinDigests": true,
  "platformAutomerge": true,
  "customManagers": [
    {
      "customType": "regex",
      "description": "https://regex101.com/r/Bf1hmQ/1 and https://regex101.com/r/SjTpfT/1",
      "fileMatch": ["(^|/)Dockerfile$"],
      "matchStrings": [
        "#.*https:\\/\\/github\\.com\/(?<depName>[^\\/]+\\/[^\\/]+)\\/(?<sourceType>(releases|tags)+).*\n(?:ENV|ARG)\\s.*_VERSION[\\s|=](?<currentValue>.*)"
      ],
      "datasourceTemplate": "github-{{{sourceType}}}"
    }
  ],
  "packageRules": [
    {
      "description": "Auto-merge minor/patch/digest for every dependency (once CI passes)",
      "matchUpdateTypes": ["minor", "patch", "digest", "pin"],
      "automerge": true
    },
    {
      "description": "Auto-merge ALL GitHub Actions updates, including major (once CI passes)",
      "matchManagers": ["github-actions"],
      "automerge": true
    }
  ]
}
